<script id="jquery-js-after">
document.addEventListener('scroll', () => {
            const scrolledClass = 'scrolled';
            if (window.scrollY > 0) {
                document.body.classList.add(scrolledClass);
            } else {
                document.body.classList.remove(scrolledClass);
            }
        });
    
//# sourceURL=jquery-js-after
