<style id="wp-custom-css">
.awsm-job-form {
    display: none;
}

.fixed-buttons {
    position: fixed;
    bottom: 10px; /* Default for larger screens */
    left: 20px; /* Default for larger screens */
    z-index: 1000;
}

/* Style for the buttons */
.fixed-buttons a {
    display: block;
    margin-bottom: 10px;
    background-color: #ED1B2F; /* Button color */
    color: white;
    text-align: center;
    padding: 10px 15px; /* Default padding */
    text-decoration: none;
    border-radius: 5px;
    font-size: 22px; /* Increased font size */
    font-weight: bold; /* Bold font */
}

body.scrolled .fixed-buttons {
    bottom: 5px; /* Adjust position for smaller margins */
    left: 15px;
}

body.scrolled .fixed-buttons a {
    padding: 3px 8px; /* Reduced padding */
    font-size: 12px; /* Smaller font size */
    font-weight: bolder; /* Lighter font weight */
    margin-bottom: 5px; /* Reduced margin between buttons */
}

/* Hover effect */
.fixed-buttons a:hover {
    background-color: #007DC5; /* Hover color */
}

/* Adjustments for 1600x900 (16:9) */
@media (max-width: 1600px) {
    .fixed-buttons a {
        padding: 8px 12px;
        font-size: 17px; /* Increased font size */
        font-weight: bold; /* Bold font */
    }
}

/* Adjustments for 1440x900 (16:10) */
@media (max-width: 1440px) {
    .fixed-buttons a {
        padding: 7px 11px;
        font-size: 17px; /* Increased font size */
        font-weight: bold; /* Bold font */
    }
}

/* Adjustments for 1368x768 (16:9) */
@media (max-width: 1368px) {
    .fixed-buttons a {
        padding: 6px 10px;
        font-size: 17px; /* Increased font size */
        font-weight: bold; /* Bold font */
    }
}

/* Adjustments for 1280x800 (16:10) */
@media (max-width: 1280px) {
    .fixed-buttons a {
        padding: 5px 9px;
        font-size: 17px; /* Increased font size */
        font-weight: bold; /* Bold font */
    }
}

/* Adjustments for 1280x720 (16:9) */
@media (max-width: 1280px) {
    .fixed-buttons a {
        padding: 5px 9px;
        font-size: 13px; /* Increased font size */
        font-weight: bold; /* Bold font */
    }
}

/* Adjustments for 1152x864 (4:3) */
@media (max-width: 1152px) {
    .fixed-buttons a {
        padding: 4px 8px;
        font-size: 12px; /* Increased font size */
        font-weight: bold; /* Bold font */
    }
}

/* Adjustments for 1024x768 (4:3) */
@media (max-width: 1024px) {
    .fixed-buttons a {
        padding: 4px 8px;
        font-size: 12px; /* Increased font size */
        font-weight: bold; /* Bold font */
    }
}

/* Adjustments for 800x600 (4:3) */
@media (max-width: 800px) {
    .fixed-buttons a {
        padding: 3px 6px;
        font-size: 11px; /* Increased font size */
        font-weight: bold; /* Bold font */
    }
}

/* Responsive adjustments for very small screens (mobile phones) */
@media (max-width: 480px) {
    .fixed-buttons {
        bottom: 5px;
        left: 5px;
    }
    .fixed-buttons a {
        padding: 2px 5px;
        font-size: 10px; /* Increased font size */
        font-weight: bold; /* Bold font */
    }
}

/* Make header sticky */
@media (max-width: 768px) {
  .header_mobile_screen {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    z-index: 999;
    background-color: #fff; /* Or your header background color */
    box-shadow: 0 2px 5px rgba(0, 0, 0, 0.1);
  }

  /* Add padding-top to body to prevent content from hiding behind header */
  body {
    padding-top: 90px; /* Adjust based on your header height */
  }
}

.header-mobile .header-mobile-content .header-content-inner .header-left .logo-mobile  {
    max-width: 90px;
    padding-top: 5px;
}
.header-mobile .header-mobile-content .header-content-inner .header-right .canvas-mobile {
    margin-left: 18px;
    max-width: 30px;
	  max-height: 30px;
    padding-top: 5px;
    /* align-content: center; */
    /* vertical-align: baseline; */
}

.wp-block-image,
figure,
.post-thumbnail {
    position: relative;
    display: inline-block;
}

.wp-block-image img,
figure img,
.post-thumbnail img {
    display: block;
}

/* .wp-block-image::after,
figure::after,
.post-thumbnail::after {
    content: "";
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.4); Overlay color
    pointer-events: none;
} */

</style>
</head>

